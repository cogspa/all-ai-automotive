<file path="fixDivs.cjs">
const fs = require('fs');
const path = require('path');

const dir = '/Users/joem/EverythingAutomotive/UltraAutomotive/src/pages';
const files = fs.readdirSync(dir).filter(f => f.endsWith('.jsx'));

files.forEach(file => {
  let content = fs.readFileSync(path.join(dir, file), 'utf-8');
  
  // Count '<div' and '</div'
  const divOpens = (content.match(/<div/g) || []).length;
  const divCloses = (content.match(/<\/div>/g) || []).length;
  
  const diff = divOpens - divCloses;
  
  if (diff > 0) {
    // missing closes
    const closes = '\n</div>'.repeat(diff);
    content = content.replace('</main>', closes + '\n</main>');
  } else if (diff < 0) {
    console.log(file, 'has too many closes', diff);
  }
  
  fs.writeFileSync(path.join(dir, file), content);
  console.log('Fixed', file, diff);
});
</file>

